<?xml version="1.0"?>
<!-- core.launch.xml — the ippolit-core systemd group: description + drivers + localization +
     safety_control. Deliberately excludes perception/navigation/viz (separate restart
     blast-radius groups, see docs/navigation-architecture.md §2.4) so e.g. a vision-pipeline
     crash-loop can't take the safety/actuation chain down with it. -->
<launch>
  <include file="$(find-pkg-share ippolit_description)/launch/description.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/drivers.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/localization.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/safety_control.launch.xml"/>
</launch>
