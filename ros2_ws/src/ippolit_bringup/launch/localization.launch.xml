<?xml version="1.0" encoding="UTF-8"?>
<!-- localization.launch.xml — EKF odometry (wheel+IMU fusion) + slam_toolbox map persistence
     (ippolit-core systemd group). slam_toolbox itself (the vendor package's async_slam_toolbox_node)
     is NOT launched here; it stays on its own standalone q6a-slam-toolbox.service for now, since its
     lifecycle configure/activate dance is a separate concern from this migration's scope (see
     docs/navigation-architecture.md's G3, A1 notes).

     Odometry: the robot_localization EKF owns odom->base_link, fusing the robot's real /odom/wheel
     + /imu/data (both tapped from AVA's MCU and forwarded to the companion). slam_toolbox provides
     map->odom on top, doing its own correlative scan matching + loop closure on /scan.

     q6a_laser_odom (custom ICP odometry) was RETIRED here 2026-07-13 (G30): it drifted in yaw, its
     /odom_laser had zero subscribers once the EKF took over odom->base_link, and slam_toolbox's own
     scan matching supersedes it. Recoverable from git if a scan-matched odom is ever wanted. -->
<launch>
  <node pkg="robot_localization" exec="ekf_node" name="ekf_filter_node">
    <param from="$(find-pkg-share ippolit_bringup)/config/ekf.yaml"/>
  </node>
  <node pkg="ippolit_localization" exec="q6a_map_persist" name="q6a_map_persist">
    <param from="$(find-pkg-share ippolit_bringup)/config/q6a_map_persist.yaml"/>
  </node>
</launch>
