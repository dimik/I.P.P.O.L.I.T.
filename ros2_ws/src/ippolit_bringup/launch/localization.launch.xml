<?xml version="1.0" encoding="UTF-8"?>
<!-- localization.launch.xml — laser-ICP odometry + slam_toolbox map persistence (ippolit-core
     systemd group). slam_toolbox itself (the vendor package's async_slam_toolbox_node) is NOT
     launched here; it stays on its own standalone q6a-slam-toolbox.service for now, since its
     lifecycle configure/activate dance is a separate concern from this migration's scope (see
     docs/navigation-architecture.md's G3 and the A1 phase notes). -->
<launch>
  <node pkg="ippolit_localization" exec="q6a_laser_odom" name="q6a_laser_odom"/>
  <node pkg="ippolit_localization" exec="q6a_map_persist" name="q6a_map_persist"/>
</launch>
