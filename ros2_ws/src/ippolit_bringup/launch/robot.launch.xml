<?xml version="1.0"?>
<!-- robot.launch.xml — top-level bringup, scaffolded in A0. Includes every group launch file.
     Each include is a stub until the corresponding phase (A1 wraps existing nodes; F1-F6 add
     features) fills it in — see docs/navigation-architecture.md. -->
<launch>
  <include file="$(find-pkg-share ippolit_description)/launch/description.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/drivers.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/localization.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/safety_control.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/perception.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/navigation.launch.xml"/>
  <include file="$(find-pkg-share ippolit_bringup)/launch/viz.launch.xml"/>
</launch>
