# Robot link for the companion ROS/vision/brownout services. Switch USB <-> WiFi HERE, then restart them:
#   sudo systemctl restart valetudo-bridge mcu-node lds-scan-node audio-bridge q6a-vision q6a-brownout
#
#   USB gadget (fast ~0.68ms, robot mounted/docked, cable-tethered):
#     ROBOT_ADDR=192.168.10.1   ROBOT_SSH=robot-usb
#   Home WiFi (free-roaming; higher latency/jitter; needs a 'robot-wifi' ssh alias on the Q6A):
#     ROBOT_ADDR=192.168.1.213  ROBOT_SSH=robot-wifi
#
# Deploy to /etc/default/ippolit-robot on the Q6A. Robot-side services bind 0.0.0.0 (no robot change needed).
ROBOT_ADDR=192.168.10.1
ROBOT_SSH=robot-usb
