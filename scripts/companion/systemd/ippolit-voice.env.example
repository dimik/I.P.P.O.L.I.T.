# Cloud voice endpoint for q6a-voice.service. Deploy as /etc/default/ippolit-voice on the Q6A
# (chmod 600, owner root) and fill in real values — NEVER commit the real file (repo is on GitHub).
VOICE_ENDPOINT=https://ippolit-voice.<subdomain>.workers.dev
VOICE_TOKEN=<output of: openssl rand -hex 32 — same value as the Worker's AUTH_TOKEN secret>
# ALSA capture device for the USB mic (find with: arecord -L). Examples: default, plughw:CARD=Device,DEV=0
VOICE_MIC=default
