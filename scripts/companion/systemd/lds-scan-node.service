[Unit]
Description=LiDAR /scan -> ROS 2 (companion; reads robot LDS tap ring via ring_forward over USB)
# Consumes the robot's /tmp/lds_ring.buf (libserialtap on ttyS3) streamed by ring_forward.py on the robot
# (tcp 192.168.10.1:9901). Publishes /scan on the Q6A. Data flows only while the LiDAR turret spins
# (fanoff-gated when docked/idle). Relocated off the robot chroot ROS.
After=network-online.target
Wants=network-online.target

[Service]
KillSignal=SIGINT
TimeoutStopSec=8
Type=simple
User=radxa
EnvironmentFile=-/etc/default/ippolit-robot
ExecStart=/bin/bash -c "source /opt/ros/jazzy/setup.bash && exec python3 /home/radxa/ros/lds_scan_node.py --ros-args -p source:=$${ROBOT_ADDR:-192.168.10.1}:9901 -p angle_offset_deg:=43.0"
# angle_offset_deg=43.0 CALIBRATED 2026-07-12 (offset value + SIGN both fixed, see lds_scan_node.py).
# Step 1: a paper bag at the robot's true front bumper read at bearing=+43deg with the previous default
# (0.0, i.e. NEVER actually calibrated despite the docstring assuming "~0-5deg"). Step 2: a wall confirmed
# on the robot's TRUE right (independently cross-checked via the MiDaS+YOLO camera stream) still read at
# LiDAR bearing +90 ("left") after fixing just the offset -- impossible from an offset error alone, only a
# wrong sign explains a left/right swap. Fixed the formula's sign in lds_scan_node.py and re-derived this
# offset (43.0, not -43.0) to keep the front calibration correct under the new sign. Re-verify with a
# second isolated-object + independent-sensor test if more precision is needed.
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
