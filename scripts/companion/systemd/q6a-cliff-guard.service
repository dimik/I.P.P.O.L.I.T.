[Unit]
Description=Companion cliff guard (SAFETY): /cliff -> hard-stop (disable manual control) to prevent falls
After=network-online.target mcu-node.service
Wants=network-online.target

[Service]
Type=simple
User=radxa
EnvironmentFile=-/etc/default/ippolit-robot
ExecStart=/bin/bash -c "source /opt/ros/jazzy/setup.bash && exec python3 /home/radxa/ros/cliff_guard.py"
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
