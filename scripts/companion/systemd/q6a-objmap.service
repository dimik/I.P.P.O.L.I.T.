[Unit]
Description=Companion semantic object map: /vision/detections + /odom + /scan -> /object_map + RViz markers
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=radxa
EnvironmentFile=-/etc/default/ippolit-robot
ExecStart=/bin/bash -c "source /opt/ros/jazzy/setup.bash && exec python3 /home/radxa/ros/q6a_objmap.py"
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
